{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"incremental": true,
		"tsBuildInfoFile": "./dist/.tsbuildinfo",
		"paths": {
			"@quangtynu/pi-ai": ["../../ai/src/index.ts"],
			"@quangtynu/pi-ai/*": ["../../ai/src/*"]
		}
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist", "**/*.d.ts", "src/**/*.d.ts"]
}
