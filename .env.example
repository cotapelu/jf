# Google OAuth Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials

# For Gemini CLI provider
GOOGLE_GEMINI_CLI_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_GEMINI_CLI_CLIENT_SECRET=your-client-secret

# For Antigravity provider (Gemini 3, Claude, GPT-OSS)
GOOGLE_ANTIGRAVITY_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_ANTIGRAVITY_CLIENT_SECRET=your-client-secret
