{
  "id": "dev",
  "name": "Development Tools",
  "description": "Testing, formatting, building, and scripting utilities",
  "version": "1.0.0",
  "tags": ["dev", "testing", "formatting", "build", "scripts"],
  "capabilities": [
    {
      "id": "test",
      "name": "Test Runner",
      "description": "Run project tests using vitest",
      "inputSchema": {
        "type": "object",
        "properties": {
          "files": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional test file paths"
          },
          "watch": {
            "type": "boolean",
            "description": "Run in watch mode (default false)"
          }
        },
        "additionalProperties": false
      },
      "execute": "capabilities/test.ts",
      "renderer": null,
      "promptGuidelines": [
        "Use dev.test to run tests.",
        "Example: { capability: 'dev.test', params: {} }",
        "Specific files: { capability: 'dev.test', params: { files: ['src/tests/foo.test.ts'] } }"
      ],
      "dependencies": []
    },
    {
      "id": "format",
      "name": "Code Formatter",
      "description": "Format code files using Prettier",
      "inputSchema": {
        "type": "object",
        "properties": {
          "files": {
            "type": "array",
            "items": { "type": "string" },
            "description": "File paths to format (required)"
          }
        },
        "required": ["files"],
        "additionalProperties": false
      },
      "execute": "capabilities/format.ts",
      "renderer": null,
      "promptGuidelines": [
        "Use dev.format to format code with Prettier.",
        "Example: { capability: 'dev.format', params: { files: ['src/index.ts'] } }"
      ],
      "dependencies": []
    },
    {
      "id": "audit",
      "name": "Security Audit",
      "description": "Check for known vulnerabilities (npm audit)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "fix": {
            "type": "boolean",
            "description": "Attempt to fix vulnerable dependencies automatically"
          }
        },
        "additionalProperties": false
      },
      "execute": "capabilities/audit.ts",
      "renderer": null,
      "promptGuidelines": [
        "Use dev.audit to check for security vulnerabilities.",
        "Example: { capability: 'dev.audit', params: { fix: true } }"
      ],
      "dependencies": []
    },
    {
      "id": "build",
      "name": "Build Project",
      "description": "Compile the project (npm run build)",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "execute": "capabilities/build.ts",
      "renderer": null,
      "promptGuidelines": [
        "Use dev.build to compile the project.",
        "Example: { capability: 'dev.build', params: {} }"
      ],
      "dependencies": []
    },
    {
      "id": "scripts",
      "name": "Run NPM Script",
      "description": "List or run npm scripts",
      "inputSchema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["list", "run"],
            "description": "Action: list scripts or run one"
          },
          "script": {
            "type": "string",
            "description": "Script name to run (required for action='run')"
          }
        },
        "required": ["action"],
        "additionalProperties": false
      },
      "execute": "capabilities/scripts.ts",
      "renderer": null,
      "promptGuidelines": [
        "Use dev.scripts to list or run npm scripts.",
        "List: { capability: 'dev.scripts', params: { action: 'list' } }",
        "Run: { capability: 'dev.scripts', params: { action: 'run', script: 'start' } }"
      ],
      "dependencies": []
    }
  ],
  "settings": {
    "enabledByDefault": true
  }
}
