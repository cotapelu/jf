{
  "id": "security",
  "name": "Security Tools",
  "description": "Security scanning and analysis",
  "version": "1.0.0",
  "tags": ["security", "scanning"],
  "capabilities": [
    {
      "id": "scan",
      "name": "Secret Scanner",
      "description": "Scan code for potential secrets (API keys, passwords, tokens)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Path to scan (default: cwd)"
          }
        },
        "additionalProperties": false
      },
      "execute": "capabilities/scan.ts",
      "renderer": null,
      "promptGuidelines": [
        "Use security.scan to find potential secrets.",
        "Example: { capability: 'security.scan', params: { path: '.' } }"
      ],
      "dependencies": []
    }
  ],
  "settings": {
    "enabledByDefault": true
  }
}
