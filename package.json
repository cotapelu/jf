{
  "name": "jf-pi-sdk",
  "version": "0.0.12",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "jf": "dist/cli.js"
  },
  "scripts": {
    "start": "tsx --tsconfig ./tsconfig.json src/main.ts",
    "prebuild": "rimraf dist && mkdir -p dist/tools/skills dist/extensions",
    "build": "tsc && cpx \"src/extensions/**/*\" dist/extensions && cpx \"src/tools/skills/skills-md/**/*.md\" dist/tools/skills/skills-md && node -e \"const fs=require('fs');const f='dist/main.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!')) fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);\" && chmod +x dist/cli.js",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.3",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pino": "^7.0.4",
    "@types/prettier": "^2.7.3",
    "@types/yaml": "^1.9.6",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "cpx": "^1.2.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "pino": "^10.3.1",
    "prettier": "^3.8.4",
    "rimraf": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "piConfig": {
    "configDir": ".jf",
    "name": "jf"
  },
  "overrides": {
    "chokidar": "^3.6.0"
  }
}
