{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"@quangtynu/pi-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@quangtynu/pi-coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@quangtynu/pi-coding-agent/*": ["./packages/coding-agent/src/*"],
			"@quangtynu/pi-coding-memory": ["./packages/memory/src/index.ts"],
			"@quangtynu/pi-coding-memory/*": ["./packages/memory/src/*"],
			"@quangtynu/pi-tools": ["./packages/tools/src/index.ts"],
			"@quangtynu/pi-tools/*": ["./packages/tools/src/*"]
		}
	},
	"include": [
		"packages/*/src/**/*",
		"packages/*/test/**/*",
		"packages/coding-agent/examples/**/*"
	],
	"exclude": [
		"packages/web-ui/**/*",
		"packages/coding-memory/test/**/*",
		"**/dist/**"
	]
}
